-- PATHFINDING MOVEMENT
local function walkPath(targetPos)
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end

    local path = Pathfinding:CreatePath({AgentRadius = 2.5, AgentCanJump = true, WaypointSpacing = 4})
    local success, _ = pcall(function() path:ComputeAsync(root.Position, targetPos) end)
    
    if success and path.Status == Enum.PathStatus.Success then
        local wps = path:GetWaypoints()
        for i = 1, math.min(#wps, 4) do
            if not _G.BotRunning or hum.Health <= 0 then break end
            hum:MoveTo(wps[i].Position)
            if wps[i].Action == Enum.PathWaypointAction.Jump then hum.Jump = true end
            local arrived = hum.MoveToFinished:Wait(0.2)
            if not arrived and root.AssemblyLinearVelocity.Magnitude < 3 then hum.Jump = true break end
        end
    else
        hum:MoveTo(targetPos)
        if root.AssemblyLinearVelocity.Magnitude < 3 then hum.Jump = true end
    end
end

local function walkDirect(targetPos)
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end

    hum:MoveTo(targetPos)
    if root.AssemblyLinearVelocity.Magnitude < 3 then hum.Jump = true end
end

-- RAYCAST WANDERING
local function getSafeWanderPos(root)
    local directions = {
        Vector3.new(1, 0, 0), Vector3.new(-1, 0, 0),
        Vector3.new(0, 0, 1), Vector3.new(0, 0, -1),
        Vector3.new(1, 0, 1).Unit, Vector3.new(-1, 0, -1).Unit
    }
    for i = #directions, 2, -1 do
        local j = math.random(i)
        directions[i], directions[j] = directions[j], directions[i]
    end
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.FilterDescendantsInstances = {player.Character}

    for _, dir in ipairs(directions) do
        local wallCheck = workspace:Raycast(root.Position, dir * 25, raycastParams)
        if not wallCheck then
            local checkPos = root.Position + (dir * 18)
            local floorCheck = workspace:Raycast(checkPos + Vector3.new(0, 2, 0), Vector3.new(0, -15, 0), raycastParams)
            if floorCheck and floorCheck.Instance and floorCheck.Instance.CanCollide then
                return checkPos
            end
        end
    end
    return root.Position - (root.CFrame.LookVector * 12)
end

-- ФУНКЦИЯ ПОИСКА САМОЙ ДЕШЕВОЙ КНОПКИ ТАЙКУНА
local function getCheapestTycoonButton(disasterFolder)
    local cheapestBtn = nil
    local lowestPrice = math.huge

    for _, obj in ipairs(disasterFolder:GetDescendants()) do
        if obj.Name == "IButton" and obj:FindFirstChild("Detect") then
            pcall(function()
                -- Проверяем путь IButton.Gui.Info.Price.Text
                local gui = obj:FindFirstChild("Gui")
                local info = gui and gui:FindFirstChild("Info")
                local priceLabel = info and info:FindFirstChild("Price")
                
                if priceLabel and (priceLabel:IsA("TextLabel") or priceLabel:IsA("TextBox")) then
                    -- Очищаем текст от знаков $, пробелов и букв, оставляя только цифры
                    local priceText = priceLabel.Text:gsub("%D", "")
                    local priceNum = tonumber(priceText)
                    
                    if priceNum and priceNum < lowestPrice then
                        lowestPrice = priceNum
                        cheapestBtn = obj:FindFirstChild("Detect")
                    end
                end
            end)
        end
    end
    return cheapestBtn, lowestPrice
end

