-- ТА САМАЯ РАБОЧАЯ ФУНКЦИЯ ХОДЬБЫ
local function walk(targetPos)
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end

    hum:MoveTo(targetPos)
    if root.AssemblyLinearVelocity.Magnitude < 3 then
        hum.Jump = true
    end
end

-- ГЛАВНЫЙ ИСПОЛНИТЕЛЬНЫЙ ЦИКЛ
task.spawn(function()
    while _G.BotRunning do
        task.wait(0.15)
        pcall(function()
            local char = player.Character
            local root = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChildOfClass("Humanoid")
            local disaster = workspace:FindFirstChild("Disaster")

            -- ОБЪЕКТЫ
            local water = disaster and disaster:FindFirstChild("Water", true)
            local win = disaster and disaster:FindFirstChild("Win", true)
            local tableBtn = disaster and disaster:FindFirstChild("TableNButtonClickDetector", true)
            local CLICKButton = workspace:FindFirstChild("CLICKButton", true)
            local weapon = char:FindFirstChild("ClassicSword") or player.Backpack:FindFirstChild("ClassicSword") or 
                           char:FindFirstChild("RocketLauncher") or player.Backpack:FindFirstChild("RocketLauncher")

            -- ЛОГИКА ПРИОРИТЕТОВ
            if water then
                status.Text = "⚡ TP: WATER EVASION"
                local high = root.Position
                for _, p in pairs(disaster:GetDescendants()) do
                    if p:IsA("BasePart") and p.CanCollide and p.Position.Y > high.Y and p.Name ~= "Water" then 
                        high = p.Position 
                    end
                end
                root.CFrame = CFrame.new(high + Vector3.new(0, 5, 0))

            elseif weapon then
                status.Text = "🚀 HUNTING: " .. weapon.Name
                if weapon.Parent == player.Backpack then hum:EquipTool(weapon) end
                local target = nil
                local dist = 1000
                for _, p in pairs(game.Players:GetPlayers()) do
                    if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
                        local d = (root.Position - p.Character.HumanoidRootPart.Position).Magnitude
                        if d < dist then dist = d target = p.Character.HumanoidRootPart end
                    end
                end
                if target then
                    walk(target.Position)
                    root.CFrame = CFrame.new(root.Position, Vector3.new(target.Position.X, root.Position.Y, target.Position.Z))
                    weapon:Activate()
                end

            elseif tableBtn then
                status.Text = "🔘 CLICKING TABLE"
                walk(tableBtn.Parent.Position)
                if (root.Position - tableBtn.Parent.Position).Magnitude < 10 then 
                    fireclickdetector(tableBtn) 
                end

            elseif win then
                status.Text = "🏆 GOING TO WIN"
                walk(win.Position)

            elseif CLICKButton then
                status.Text = "🎮 GOING TO START"
                local pos = CLICKButton:IsA("BasePart") and CLICKButton.Position or CLICKButton.Parent.Position
                walk(pos)
                if (root.Position - pos).Magnitude < 10 then
                    fireclickdetector(CLICKButton:FindFirstChildOfClass("ClickDetector") or CLICKButton)
                end
            else
                status.Text = "🚶 WANDERING..."
                if tick() - lastWander > 3 or not wanderTarget then
                    lastWander = tick()
                    wanderTarget = root.Position + Vector3.new(math.random(-30, 30), 0, math.random(-30, 30))
                end
                walk(wanderTarget)
            end
        end)
    end
end)
